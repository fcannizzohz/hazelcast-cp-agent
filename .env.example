# ── LLM credentials ────────────────────────────────────────────────────────
# At least one API key is required.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── External service endpoints ──────────────────────────────────────────────
# URLs must be reachable from inside the agent container.
# Use host.docker.internal to reach services running on the Docker host.
PROMETHEUS_URL=http://host.docker.internal:9090
MC_URL=http://host.docker.internal:8080
MC_CLUSTER=dev

# ── Hazelcast members ───────────────────────────────────────────────────────
HZ_MEMBERS=hz1,hz2,hz3,hz4,hz5

# Optional: explicit host:port pairs for the Hazelcast REST health check
# (/hazelcast/health). Required when the agent runs outside the cluster network.
# Example for 5 members on the Docker host:
#   HZ_MEMBER_ADDRS=host.docker.internal:5701,host.docker.internal:5702,host.docker.internal:5703,host.docker.internal:5704,host.docker.internal:5705
HZ_MEMBER_ADDRS=

# ── File access ─────────────────────────────────────────────────────────────
# docker  — access container filesystem and logs via Docker socket
#            (requires /var/run/docker.sock mount)
# files   — read logs and config from FILE_DIR/{member}/ on the local filesystem
# none    — disable all file access tools
FILE_ACCESS_BACKEND=docker
FILE_DIR=/logs

# ── Agent port ──────────────────────────────────────────────────────────────
AGENT_PORT=8000
